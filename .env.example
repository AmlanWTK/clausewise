# Copy to .env and fill in. NEVER commit .env.
# Values here are safe defaults for local development.

# --- Database (Checkpoint 2) ---
DATABASE_URL=postgresql+asyncpg://clausewise:clausewise@localhost:5432/clausewise

# --- LLM provider (Checkpoint 13) ---
# Gemini API key from https://aistudio.google.com (free tier, no card needed)
GEMINI_API_KEY=

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=development
