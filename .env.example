# Copy to .env and fill in. NEVER commit .env.
# Values here are safe defaults for local development.

# --- Database (Checkpoint 2) ---
# Port 5433 = the docker/compose.yml container (5432 is often taken by a
# locally installed PostgreSQL).
DATABASE_URL=postgresql+asyncpg://clausewise:clausewise@localhost:5433/clausewise

# --- LLM provider (Checkpoint 13) ---
# Gemini API key from https://aistudio.google.com (free tier, no card needed)
GEMINI_API_KEY=

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=development
